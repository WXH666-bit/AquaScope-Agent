OPENROUTER_API_KEY=replace_with_your_openrouter_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=nex-agi/nex-n2-pro:free
OPENROUTER_SITE_URL=http://localhost:8501
OPENROUTER_APP_NAME=AquaBio-AgentRAG
# Set both to qwen to use Alibaba Model Studio for text and images.
AQUABIO_LLM_PROVIDER=openrouter
AQUABIO_VISION_PROVIDER=auto
AQUABIO_LLM_CONNECT_TIMEOUT=10
AQUABIO_LLM_READ_TIMEOUT=60
QWEN_API_KEY=replace_with_your_qwen_api_key
# QWEN_KEY_FILE=F:\rag\阿里云的key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.7-plus
RAGANYTHING_TEXT_LLM_PROVIDER=qwen
DEEPSEEK_API_KEY=replace_with_your_deepseek_key
# Or keep the key outside the project:
# DEEPSEEK_KEY_FILE=F:\rag\deepseek的key.txt
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash
PIP_CACHE_DIR=F:\pip-cache
HF_HOME=F:\huggingface
HUGGINGFACE_HUB_CACHE=F:\huggingface\hub
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
MODELSCOPE_CACHE=F:\modelscope
GEMINI_API_KEY=replace_with_your_gemini_key
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_VISION_MODEL=gemini-2.5-flash
GEMINI_VISION_FALLBACK_MODEL=gemini-2.5-flash-lite
RAGANYTHING_PARSER=mineru
RAGANYTHING_PARSE_METHOD=auto
RAGANYTHING_PARSER_BACKEND=pipeline
RAGANYTHING_EMBEDDING_DIM=1024
RAGANYTHING_MAX_SEGMENT_PAGES=40
RAGANYTHING_SEGMENT_OVERLAP=1
RAGANYTHING_MIN_IMAGE_SIZE=256
MRAG_EMBEDDING_MODEL=BAAI/bge-m3
MRAG_MODEL_CACHE=F:\huggingface\aquabio
MRAG_LOCAL_FILES_ONLY=true
MRAG_COLLECTION_NAME=aquabio_mrag
MRAG_TOP_K=12
MRAG_RERANK_TOP_K=6
MRAG_MAX_RETRY=2
# LightRAG hybrid query may be slow on CPU/free APIs. When true, each failed
# query is limited to 20 seconds and then falls back to Chroma + BM25.
MRAG_USE_GRAPH_MCP=true
MRAG_REACT_NATIVE=true
RAGANYTHING_MCP_URL=http://127.0.0.1:8765/mcp
RAGANYTHING_MCP_TIMEOUT=35
RAGANYTHING_QUERY_TIMEOUT=25
AQUABIO_CHAT_UI_TIMEOUT=360
AQUABIO_API_URL=http://127.0.0.1:8000
