  <data key="d0">Base Arm Spines</data>
  <data key="d1">anatomical_feature</data>
  <data key="d2">Strong spines along the base of arms in P. echinaster.</data>
  <data key="d3">chunk-b7d87a9fdd6796fbc3a24c40022179ca</data>
