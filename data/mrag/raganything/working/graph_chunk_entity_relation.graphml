<node id="Stellate Body Form">
  <data key="d0">Stellate Body Form</data>
  <data key="d1">anatomical_feature</data>
  <data key="d2">A short-armed, stellate body form characteristic of P. echinaster.</data>
  <data key="d3">chunk-b7d87a9fdd6796fbc3a24c40022179ca</data>
