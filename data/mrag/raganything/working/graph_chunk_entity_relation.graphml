<node id="Poraniopsis echinaster">
  <data key="d0">Poraniopsis echinaster</data>
  <data key="d1">species</data>
  <data key="d2">Poraniopsis echinaster is a species of starfish commonly known as the Spiky cushion star, belonging to family Poraniidae, with a short-armed stellate body, reticular skeleton, raised spines 1–4 mm, color ranging from deep orange to red or white, and size averaging 50 mm up to 160 mm diameter.</data>
  <data key="d3">chunk-83d371544d6eb48b5321717428ea68f1</data>
  <data key="d4">Field-Guide-to-SA-Offshore-Marine-Invertebrates_web-full-version_compressed.pdf</data>
  <data key="d5">1781097491</data>
  <data key="d6"></data>
</node>
