  <data key="d6"></data>
</node>
<node id="Adambulacral Spines">
  <data key="d0">Adambulacral Spines</data>
  <data key="d1">anatomical_feature</data>
  <data key="d2">Fine raised bumps (sheaths of adambulacral spines) forming distinct rows along each arm of the Inflexible Rigid Star; no spines apparent.&lt;SEP&gt;Fine raised bumps (sheaths of adambulacral spines) form distinct rows along each arm.</data>
  <data key="d3">chunk-01224e247c54c26376338d1d355035dc&lt;SEP&gt;chunk-43c53974450202fe6a82416f946fc26f</data>
