<node id="Arm Rigidity">
  <data key="d0">Arm Rigidity</data>
  <data key="d1">anatomical_feature</data>
  <data key="d2">The arms of P. echinaster are fairly rigid.</data>
  <data key="d3">chunk-b7d87a9fdd6796fbc3a24c40022179ca</data>
