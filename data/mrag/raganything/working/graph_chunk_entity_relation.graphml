<node id="Inflexible Rigid Starfish">
  <data key="d0">Inflexible Rigid Starfish</data>
  <data key="d1">taxon</data>
  <data key="d2">A thick fleshy starfish with an inflexible, rigid star shape, pentagonal disc, indistinct marginal plates, distinct madreporite, and fine raised bumps along arms. It has smooth aboral and oral surfaces and double rows of tube feet.</data>
  <data key="d3">chunk-01224e247c54c26376338d1d355035dc</data>
  <data key="d4">Field-Guide-to-SA-Offshore-Marine-Invertebrates_web-full-version_compressed.pdf</data>
  <data key="d5">1781097486</data>
  <data key="d6"></data>
</node>
<node id="Disc">
  <data key="d0">Disc</data>
  <data key="d1">anatomical_feature</data>
  <data key="d2">Thick, solid, spongy disc of the Inflexible Rigid Star, pentagonal in shape.&lt;SEP&gt;Thick, solid, spongy, and pentagonal in shape.</data>
  <data key="d3">chunk-01224e247c54c26376338d1d355035dc&lt;SEP&gt;chunk-43c53974450202fe6a82416f946fc26f</data>
