        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Clark AM and Downey ME. 1992. Starfishes of the Atlantic (Volume 3). Chapman and Hall: London. pp. 202-204 (794pp.)."
                    }
                ]
            },
            "bbox": [
                509,
                680,
                836,
                724
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Species identification confirmed by Dr C. Mah, Smithsonian, Washington, June 2015."
                    }
                ]
