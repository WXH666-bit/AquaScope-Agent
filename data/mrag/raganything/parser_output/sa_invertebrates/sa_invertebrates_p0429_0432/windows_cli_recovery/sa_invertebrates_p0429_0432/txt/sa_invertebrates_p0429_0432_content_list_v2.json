        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "distinguishing features"
                    }
                ],
                "level": 2
            },
            "bbox": [
                161,
                575,
                322,
                592
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "attribute": "unordered",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "Arms usually break off central disc very easily."
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "Distinct spines protrude from aboral margin edge;"
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "arms long, flexible, flattened and tapering, strap-like."
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "Usually five arms."
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                161,
                592,
                489,
                650
            ]
        },
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "Colour"
                    }
                ],
                "level": 2
            },
            "bbox": [
                163,
                663,
                211,
                677
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Brown to dark pink."
                    }
                ]
            },
            "bbox": [
                161,
                678,
                290,
                693
            ]
        },
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "Size"
                    }
                ],
                "level": 2
            },
            "bbox": [
                163,
                706,
                194,
                721
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Average up to 150 mm diameter, but can get larger individuals."
                    }
                ]
            },
            "bbox": [
                161,
                722,
                487,
                751
            ]
        },
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "distribution"
                    }
                ],
                "level": 2
            },
            "bbox": [
                163,
                764,
                247,
                780
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Southern African endemic. West and South Coasts of South Africa, to Port Elizabeth; 54 m to 360+ m depth."
                    }
                ]
            },
            "bbox": [
                161,
                781,
                489,
                825
            ]
        },
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "Similar species"
                    }
                ],
                "level": 2
            },
            "bbox": [
                509,
                575,
                615,
                592
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Astropecten polyacanthus and Astropecten exilis, however arms of Luidia africana are more flattened and broader, i.e. less tapered, and break off central disc easily."
                    }
                ]
            },
            "bbox": [
                507,
                592,
                836,
                650
            ]
        },
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "references"
                    }
                ],
                "level": 2
            },
            "bbox": [
                509,
                663,
                589,
                677
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Clark AM and Downey ME. 1992. Starfishes of the Atlantic (Volume 3). Chapman and Hall: London. p. 20. (794pp.)."
                    }
                ]
            },
            "bbox": [
                509,
                677,
                836,
                722
            ]
