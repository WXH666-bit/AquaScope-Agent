                589,
                630
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Clark AM and Courtman-Stock J. 1976. The Echinoderms of Southern Africa. British Museum (Natural History): London. pp. 73-74 (277pp.)."
                    }
                ]
            },
            "bbox": [
                509,
