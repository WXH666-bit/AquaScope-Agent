        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "distinguishing features"
                    }
                ],
                "level": 2
            },
            "bbox": [
                161,
                575,
                322,
                592
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Pentagonal in shape, cushion-like body, often inflated when landed (as in photo), but slowly deflates with time out of water. Numerous papillae coat the aboral surface. Ventral smooth with fine lines."
                    }
                ]
            },
            "bbox": [
                161,
                592,
                489,
                664
            ]
        },
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "Colour"
                    }
                ],
                "level": 2
            },
            "bbox": [
                161,
                676,
                211,
                692
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Speckled brilliant orange aboral surface and pale cream smooth oral surface."
                    }
                ]
            },
            "bbox": [
                161,
                693,
                487,
                722
            ]
        },
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "Size"
                    }
                ],
                "level": 2
            },
            "bbox": [
                163,
                734,
                194,
                750
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Up to 160 mm diameter."
                    }
                ]
            },
            "bbox": [
                161,
                751,
                321,
                766
            ]
        },
        {
            "type": "image",
            "content": {
                "image_source": {
