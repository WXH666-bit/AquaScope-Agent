                590
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "West and South Coasts of South Africa; from 40 to 205+ m depth."
                    }
                ]
            },
            "bbox": [
                509,
                590,
                835,
                621
            ]
        },
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "Similar species"
                    }
                ],
                "level": 2
            },
            "bbox": [
