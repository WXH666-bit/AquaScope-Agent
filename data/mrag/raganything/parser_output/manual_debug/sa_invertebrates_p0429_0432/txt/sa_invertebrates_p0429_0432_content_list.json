    {
        "type": "image",
        "img_path": "images/b8755a5ccc6dfd3f35a9ef6b4f2ca5a2c63ef7839753a0a71e697dcfc2117d47.jpg",
        "image_caption": [],
        "image_footnote": [],
        "bbox": [
