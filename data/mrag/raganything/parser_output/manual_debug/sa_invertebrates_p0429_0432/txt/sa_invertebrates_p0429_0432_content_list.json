        "table_body": "<table><tr><td rowspan=1 colspan=2>Spoladaster veneris (SpoBra)</td></tr><tr><td rowspan=1 colspan=1>Phylum:</td><td rowspan=1 colspan=1>Echinodermata</td></tr><tr><td rowspan=1 colspan=1>Class:</td><td rowspan=1 colspan=1>Asteroidea</td></tr><tr><td rowspan=1 colspan=1>Order:</td><td rowspan=1 colspan=1>Valvatida</td></tr><tr><td rowspan=1 colspan=1>Family:</td><td rowspan=1 colspan=1>Poraniidae</td></tr><tr><td rowspan=1 colspan=1>Genus:</td><td rowspan=1 colspan=1>Spoladaster</td></tr><tr><td rowspan=1 colspan=1>Species:</td><td rowspan=1 colspan=1>veneris</td></tr><tr><td rowspan=1 colspan=2>Common name:    Inflated star</td></tr></table>",
        "bbox": [
