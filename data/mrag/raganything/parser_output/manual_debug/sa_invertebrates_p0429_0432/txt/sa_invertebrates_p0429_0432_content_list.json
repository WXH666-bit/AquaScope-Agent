            "Poraniopsis echinaster (PorEch)"
        ],
        "table_footnote": [],
        "table_body": "<table><tr><td rowspan=1 colspan=1>Phylum:</td><td rowspan=1 colspan=1>Echinodermata</td></tr><tr><td rowspan=1 colspan=1>Class:</td><td rowspan=1 colspan=1>Asteriodea</td></tr><tr><td rowspan=1 colspan=1>Order:</td><td rowspan=1 colspan=1>Valvatida</td></tr><tr><td rowspan=1 colspan=1>Family:</td><td rowspan=1 colspan=1>Poraniidae</td></tr><tr><td rowspan=1 colspan=1>Genus:</td><td rowspan=1 colspan=1>Poraniopsis</td></tr><tr><td rowspan=1 colspan=1>Species:</td><td rowspan=1 colspan=1>echinaster</td></tr><tr><td rowspan=1 colspan=1>Common name:</td><td rowspan=1 colspan=1>Spiky cushion star</td></tr></table>",
        "bbox": [
            163,
            147,
            571,
            299
        ],
        "page_idx": 3
    },
    {
        "type": "image",
        "img_path": "images/cbd2e97b7c582dd2d79fb70858886ed094345dc1c9c3275de598a6ec8ea4e0d4.jpg",
        "image_caption": [],
        "image_footnote": [],
        "bbox": [
            163,
            322,
            487,
            551
        ],
        "page_idx": 3
    },
    {
        "type": "chart",
        "img_path": "images/4298e191b0e01c7171eb8aef595fd07f06cb57314c411c3b17a683a6d5a25de2.jpg",
        "content": "",
        "chart_caption": [],
